---
/* ── Deterministic star field (golden-ratio distribution) ── */
const stars = Array.from({ length: 110 }, (_, i) => ({
  id: i,
  x: +((i * 137.508) % 100).toFixed(1),
  y: +((i * 97.314 + i * 1.7) % 100).toFixed(1),
  r: 1 + (i % 3),
  o: +(0.05 + (i % 9) * 0.035).toFixed(2),
  pulse: i % 6 === 0,
}));

/* ── SVG icon paths (24×24, stroke-based) ── */
const icons: Record<string, string> = {
  db:    `<ellipse cx="12" cy="6" rx="9" ry="3"/>
          <path d="M3 6v4c0 1.66 4 3 9 3s9-1.34 9-3V6"/>
          <path d="M3 10v4c0 1.66 4 3 9 3s9-1.34 9-3v-4"/>
          <path d="M3 14v4c0 1.66 4 3 9 3s9-1.34 9-3v-4"/>`,
  truck: `<path d="M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h11a2 2 0 012 2v3"/>
          <polygon points="16 3 21 8 21 17 16 17 16 3"/>
          <circle cx="7" cy="17" r="2"/>
          <circle cx="17" cy="17" r="2"/>
          <line x1="9" y1="17" x2="15" y2="17"/>`,
  chart: `<rect x="2"  y="14" width="4" height="7" rx="1"/>
          <rect x="9"  y="9"  width="4" height="12" rx="1"/>
          <rect x="16" y="4"  width="4" height="17" rx="1"/>`,
  doc:   `<path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8l-6-6z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>`,
  park:  `<rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M9 17V7h4a3 3 0 010 6H9"/>`,
  screen:`<rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8"  y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>`,
  play:  `<circle cx="12" cy="12" r="10"/>
          <polygon points="10 8 16 12 10 16 10 8"/>`,
  ai:    `<path d="M9.663 17h4.674M12 3v1m6.364 1.636-.707.707M21 12h-1M4 12H3m3.343-5.657-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/>`,
  bal:   `<line x1="12" y1="3" x2="12" y2="21"/>
          <path d="M7 5H3l-1 9h6L7 5z"/>
          <path d="M17 5h4l1 9h-6l1-9z"/>
          <line x1="2" y1="21" x2="22" y2="21"/>`,
};

/* ── Planet definitions ── */
const planets = [
  /* ── Inner orbit · Refugio Data · Gold · CW ── */
  { id:'p-proc',   label:'Procesamiento Data', full:'Módulo Procesamiento Data',     desc:'Gestión y análisis de datos operativos',   href:'https://datarefugio.gcbprojects.site/legacy',    color:'#C9A84C', bg:'rgba(201,168,76,0.13)',  glow:'rgba(201,168,76,0.55)',  group:'Refugio Data', orbit:'inner',  phase:270, speed:0.30, dir: 1, icon:'db'    },
  { id:'p-del',    label:'Delivery',      full:'Módulo Delivery',          desc:'Control y seguimiento de pedidos',          href:'https://datarefugio.gcbprojects.site/delivery',  color:'#DEB86A', bg:'rgba(222,184,106,0.13)', glow:'rgba(222,184,106,0.55)', group:'Refugio Data', orbit:'inner',  phase:30,  speed:0.30, dir: 1, icon:'truck' },
  { id:'p-com',    label:'Comercial',     full:'Módulo Comercial',         desc:'Reservas, eventos y CRM',                   href:'https://datarefugio.gcbprojects.site/comercial', color:'#F0CC7A', bg:'rgba(240,204,122,0.13)', glow:'rgba(240,204,122,0.55)', group:'Refugio Data', orbit:'inner',  phase:150, speed:0.30, dir: 1, icon:'chart' },
  { id:'p-docgcb', label:'Documentación GCB', full:'Documentación GCB',    desc:'Documentos y consultas GCB',  href:'https://datarefugio.gcbprojects.site/documentos-gcb', color:'#E0C46E', bg:'rgba(224,196,110,0.13)', glow:'rgba(224,196,110,0.55)', group:'Refugio Data', orbit:'inner',  phase:210, speed:0.30, dir: 1, icon:'doc' },
  /* ── Middle orbit · Sistemas & Apps · CCW ── */
  { id:'p-est',    label:'Estacionam.',   full:'Sistema Estacionamiento',  desc:'Gestión de estacionamiento',                href:'https://estacionamiento.gcbprojects.site/',       color:'#9B6DFF', bg:'rgba(155,109,255,0.13)', glow:'rgba(155,109,255,0.55)', group:'Sistema',      orbit:'middle', phase:90,  speed:0.20, dir:-1, icon:'park'  },
  { id:'p-kiosk',  label:'Web Kiosko',    full:'Web Kiosko',               desc:'Punto de venta en navegador',                 href:'https://kiosk.datarefugio.gcbprojects.site/',   color:'#3CC9A4', bg:'rgba(60,201,164,0.13)',  glow:'rgba(60,201,164,0.55)',  group:'Descarga',     orbit:'middle', phase:330, speed:0.20, dir:-1, icon:'screen'},
  { id:'p-runner', label:'App Runner',    full:'App Runner',               desc:'Descarga · App de despacho',                href:'https://expo.dev/accounts/refugdata/projects/runner/builds/35f63aa4-b981-47eb-b276-b5ff2c801dc0',   color:'#FF8C42', bg:'rgba(255,140,66,0.13)',  glow:'rgba(255,140,66,0.55)',  group:'Descarga',     orbit:'middle', phase:210, speed:0.20, dir:-1, icon:'play'  },
  /* ── Outer orbit · Tools · CW ── */
  { id:'p-ai',   label:'Agente AI',     full:'Consultas Agente AI',      desc:'Consultas con inteligencia artificial',     href:'http://62.169.23.24:8083/',                      color:'#4A9EFF', bg:'rgba(74,158,255,0.13)',  glow:'rgba(74,158,255,0.55)',  group:'Herramienta',  orbit:'outer',  phase:45,  speed:0.13, dir: 1, icon:'ai'    },
  { id:'p-conc', label:'Conciliación',  full:'Conciliación Financiera',  desc:'Sistema de conciliación financiera',        href:'http://62.169.23.24:8082/login',                 color:'#FF6B8E', bg:'rgba(255,107,142,0.13)', glow:'rgba(255,107,142,0.55)', group:'Sistema',      orbit:'outer',  phase:225, speed:0.13, dir: 1, icon:'bal'   },

];

const scriptData = JSON.stringify(
  planets.map(({ id, orbit, phase, speed, dir }) => ({ id, orbit, phase, speed, dir }))
);

/* Mobile group order */
const mobileGroups = [
  { key: 'Refugio Data', sub: 'datarefugio.gcbprojects.site' },
  { key: 'Sistema',      sub: 'Sistemas internos' },
  { key: 'Descarga',     sub: 'Aplicaciones móviles' },
  { key: 'Herramienta',  sub: 'Herramientas avanzadas' },
];
---

<div class="page">

  <!-- ════════════════ HEADER ════════════════ -->
  <header class="hd">
    <div class="hd-in">
      <span class="hd-name">Grupo Cordillera Blanca SA</span>
      <div class="hd-right">
        <span class="hd-tag">Portal</span>
        <button class="theme-btn" id="theme-toggle" aria-label="Cambiar tema" title="Cambiar tema">
          <!-- Sol: visible en dark mode para volver a light -->
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <!-- Luna: visible en light mode para pasar a dark -->
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
      </div>
    </div>
  </header>

  <!-- ════════════════ COSMOS (desktop) ════════════════ -->
  <div class="cosmos-wrap" id="gcb-wrap">
    <div class="cosmos" id="gcb-cosmos">

      <!-- Stars -->
      {stars.map(s => (
        <span
          class={`star${s.pulse ? ' star-p' : ''}`}
          style={`left:${s.x}%;top:${s.y}%;width:${s.r}px;height:${s.r}px;opacity:${s.o}`}
        />
      ))}

      <!-- Nebula ambient -->
      <div class="nebula" aria-hidden="true" />

      <!-- Orbit ring labels -->
      <span class="rlabel rl-inner"  aria-hidden="true">Refugio Data</span>
      <span class="rlabel rl-middle" aria-hidden="true">Sistemas &amp; Apps</span>
      <span class="rlabel rl-outer"  aria-hidden="true">Herramientas</span>

      <!-- Orbit rings -->
      <div class="ring ring-i" aria-hidden="true" />
      <div class="ring ring-m" aria-hidden="true" />
      <div class="ring ring-o" aria-hidden="true" />

      <!-- Center star -->
      <div class="cstar">
        <div class="ch ch-1" aria-hidden="true" />
        <div class="ch ch-2" aria-hidden="true" />
        <div class="ch ch-3" aria-hidden="true" />
        <div class="cbody">
          <h1 class="ch1">Grupo<br/>Cordillera<br/>Blanca SA</h1>
          <p class="csub">Proyectos</p>
        </div>
      </div>

      <!-- Planets -->
      {planets.map(p => (
        <div
          id={p.id}
          class="planet"
          data-href={p.href}
          style={`--pc:${p.color};--pb:${p.bg};--pg:${p.glow}`}
          tabindex="0"
          role="button"
          aria-label={`Abrir ${p.full}`}
        >
          <!-- Bubble -->
          <div class="pbub">
            <div class="pbub-ring" aria-hidden="true" />
            <svg
              class="pico"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.7"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons[p.icon]}
            />
          </div>

          <!-- Label always visible -->
          <span class="plabel">{p.label}</span>

          <!-- Tooltip on hover -->
          <div class="ptip" role="tooltip">
            <span class="ptip-grp">{p.group}</span>
            <strong class="ptip-title">{p.full}</strong>
            <p class="ptip-desc">{p.desc}</p>
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="ptip-btn"
            >
              Abrir
              <svg viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" width="12" height="12">
                <path d="M6 2H2a1 1 0 00-1 1v9a1 1 0 001 1h9a1 1 0 001-1V8"/>
                <path d="M9 1h4v4"/>
                <line x1="13" y1="1" x2="6" y2="8"/>
              </svg>
            </a>
          </div>
        </div>
      ))}

    </div><!-- /cosmos -->
  </div><!-- /cosmos-wrap -->

  <!-- ════════════════ MOBILE ════════════════ -->
  <div class="mob" aria-label="Proyectos">
    <div class="mob-hero">
      <h1 class="mob-h1">Grupo Cordillera<br/>Blanca SA</h1>
      <p class="mob-sub">Proyectos</p>
    </div>

    {mobileGroups.map(({ key, sub }) => {
      const grp = planets.filter(p => p.group === key);
      if (!grp.length) return null;
      return (
        <div class="mob-grp">
          <div class="mob-gh">
            <span class="mob-dot" style={`background:${grp[0].color};box-shadow:0 0 8px ${grp[0].glow}`} />
            <div>
              <b class="mob-gname">{key}</b>
              <span class="mob-gsub">{sub}</span>
            </div>
          </div>
          <div class="mob-cards">
            {grp.map(p => (
              <a
                href={p.href}
                target="_blank"
                rel="noopener noreferrer"
                class="mob-card"
                style={`--mc:${p.color};--mg:${p.glow};--mb:${p.bg}`}
              >
                <div class="mc-ico">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" set:html={icons[p.icon]} />
                </div>
                <div class="mc-body">
                  <p class="mc-title">{p.full}</p>
                  <p class="mc-desc">{p.desc}</p>
                </div>
                <svg class="mc-arr" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                  <path d="M6 2H2a1 1 0 00-1 1v9a1 1 0 001 1h9a1 1 0 001-1V8"/>
                  <path d="M9 1h4v4"/><line x1="13" y1="1" x2="6" y2="8"/>
                </svg>
              </a>
            ))}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Footer -->
  <footer class="ft">
    <p>© {new Date().getFullYear()} Grupo Cordillera Blanca SA</p>
  </footer>

  <!-- Data bridge for script -->
  <div id="gcb-data" data-v={scriptData} hidden />
</div>

<!-- ════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════ -->
<style>
/* ── CSS Variables — light mode (default) ───────────── */
:root {
  --fd: 'Work Sans', sans-serif;
  --fb: 'Manrope', sans-serif;

  /* Superficie / texto */
  --bg:         #F8F5EF;
  --surface:    rgba(255,255,255,0.92);
  --surf-dark:  rgba(255,255,255,0.96);
  --text:       #1C1814;
  --muted:      rgba(28,24,20,0.50);
  --dim:        rgba(28,24,20,0.22);
  --orbit-label: rgba(28,24,20,0.44);
  --border:     rgba(28,24,20,0.09);

  /* Dorado adaptado a fondo claro */
  --gold:        #C9A84C;
  --gold-light:  rgba(201,168,76,0.12);
  --gold-glow:   rgba(201,168,76,0.35);
  --gold-border: rgba(180,140,60,0.28);
  --gold-text:   #8A6318;

  /* Capas UI */
  --hdr-bg:     rgba(248,245,239,0.94);
  --tip-bg:     rgba(255,255,255,0.98);
  --card-bg:    rgba(255,255,255,0.85);
  --body-bg:    rgba(255,255,255,0.96);
  --star-col:   rgba(0,0,0,0.09);
  --scroll-bg:  #e4dfd4;
}

/* ── CSS Variables — dark mode ──────────────────────── */
html.dark {
  --bg:         #0A0A0A;
  --surface:    rgba(14,14,14,0.97);
  --surf-dark:  rgba(8,8,8,0.92);
  --text:       #F5EDD8;
  --muted:      rgba(245,237,216,0.48);
  --dim:        rgba(245,237,216,0.18);
  --orbit-label: rgba(245,237,216,0.46);
  --border:     rgba(201,168,76,0.15);

  --gold:        #C9A84C;
  --gold-light:  rgba(201,168,76,0.13);
  --gold-glow:   rgba(201,168,76,0.55);
  --gold-border: rgba(201,168,76,0.28);
  --gold-text:   rgba(201,168,76,0.80);

  --hdr-bg:     rgba(10,10,10,0.88);
  --tip-bg:     rgba(14,14,14,0.97);
  --card-bg:    rgba(24,24,24,0.75);
  --body-bg:    rgba(8,8,8,0.92);
  --star-col:   #F5EDD8;
  --scroll-bg:  #111;
}

/* ── Page ──────────────────────────────────────────── */
.page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
  color: var(--text);
  font-family: var(--fb);
  transition: background .3s, color .3s;
  overflow-x: hidden;
}

/* ── Header ────────────────────────────────────────── */
.hd {
  position: sticky; top: 0; z-index: 200;
  background: var(--hdr-bg);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(18px);
  flex-shrink: 0;
  transition: background .3s, border-color .3s;
}
.hd-in {
  max-width: 1200px; margin: 0 auto;
  padding: 0.65rem 1.25rem;
  display: flex; align-items: center; gap: 0.75rem;
}
.hd-name {
  font-family: var(--fd); font-weight: 700;
  font-size: 0.92rem;
  background: linear-gradient(90deg, #C9A84C 0%, #9B6DFF 38%, #3CC9A4 72%, #FF8C42 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
  letter-spacing: 0.01em;
}
.hd-right {
  margin-left: auto;
  display: flex; align-items: center; gap: 0.6rem;
}
.hd-tag {
  font-size: 0.6rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.14em;
  color: var(--gold-text);
  background: var(--gold-light);
  border: 1px solid var(--gold-border);
  border-radius: 99px;
  padding: 0.2rem 0.65rem;
  transition: color .3s, background .3s, border-color .3s;
}

/* ── Theme toggle ───────────────────────────────────── */
.theme-btn {
  width: 34px; height: 34px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--surface);
  color: var(--text);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: border-color .2s, background .2s, color .2s, box-shadow .2s;
}
.theme-btn:hover {
  border-color: var(--gold);
  color: var(--gold);
  box-shadow: 0 0 10px var(--gold-glow);
}
/* Sol visible en dark (para volver a light), Luna visible en light (para ir a dark) */
.icon-sun  { display: none; }
.icon-moon { display: block; }
html.dark .icon-sun  { display: block; }
html.dark .icon-moon { display: none; }

/* ── Cosmos wrap ───────────────────────────────────── */
.cosmos-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
  overflow: visible;
}
.cosmos {
  position: relative;
  width: 920px; height: 920px;
  flex-shrink: 0;
  transform-origin: center center;
  overflow: visible;
}

/* ── Stars ─────────────────────────────────────────── */
.star {
  position: absolute;
  border-radius: 50%;
  background: var(--star-col);
  pointer-events: none;
}
@keyframes spulse {
  0%,100% { transform: scale(1); }
  50%      { transform: scale(2.2); opacity: 0.9; }
}
.star-p { animation: spulse 4s ease-in-out infinite; }

/* ── Nebula ────────────────────────────────────────── */
.nebula {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  background:
    radial-gradient(ellipse at 35% 40%, rgba(201,168,76,0.07)  0%, transparent 45%),
    radial-gradient(ellipse at 65% 60%, rgba(155,109,255,0.05) 0%, transparent 45%),
    radial-gradient(ellipse at 50% 80%, rgba(60,201,164,0.04)  0%, transparent 40%),
    radial-gradient(ellipse at 30% 75%, rgba(74,158,255,0.04)  0%, transparent 40%);
  pointer-events: none;
  animation: nebula 20s ease-in-out infinite alternate;
}
@keyframes nebula {
  from { transform: scale(1)   rotate(0deg); }
  to   { transform: scale(1.1) rotate(12deg); }
}

/* ── Orbit ring labels ─────────────────────────────── */
.rlabel {
  position: absolute;
  top: 50%; left: 50%;
  font-size: 0.55rem;
  font-family: var(--fb);
  font-weight: 500;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--orbit-label);
  white-space: nowrap;
  pointer-events: none;
  transform: translateX(-50%);
}
.rl-inner  { margin-top: calc(-200px - 18px); }
.rl-middle { margin-top: calc(-320px - 18px); }
.rl-outer  { margin-top: calc(-420px - 18px); }

/* ── Orbit rings ───────────────────────────────────── */
.ring {
  position: absolute;
  top: 50%; left: 50%;
  border-radius: 50%;
  pointer-events: none;
}
@keyframes rs  { to { transform: translate(-50%,-50%) rotate( 360deg); } }
@keyframes rsr { to { transform: translate(-50%,-50%) rotate(-360deg); } }

.ring-i {
  width: 400px; height: 400px;
  border: 1px dashed rgba(201,168,76,0.32);
  transform: translate(-50%,-50%);
  box-shadow: 0 0 30px rgba(201,168,76,0.06) inset;
  animation: rs  70s linear infinite;
}
.ring-m {
  width: 640px; height: 640px;
  border: 1px dashed rgba(155,109,255,0.24);
  transform: translate(-50%,-50%);
  animation: rsr 100s linear infinite;
}
.ring-o {
  width: 840px; height: 840px;
  border: 1px dashed rgba(74,158,255,0.18);
  transform: translate(-50%,-50%);
  animation: rs  140s linear infinite;
}

/* ── Center star ───────────────────────────────────── */
.cstar {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%,-50%);
  display: flex; align-items: center; justify-content: center;
  z-index: 5;
}
@keyframes hpulse  { 0%,100% { transform:translate(-50%,-50%) scale(1);   opacity:.45; } 50% { transform:translate(-50%,-50%) scale(1.25); opacity:.75; } }
@keyframes hpulse2 { 0%,100% { transform:translate(-50%,-50%) scale(1);   opacity:.2;  } 50% { transform:translate(-50%,-50%) scale(1.45); opacity:.4;  } }
@keyframes hpulse3 { 0%,100% { transform:translate(-50%,-50%) scale(1);   opacity:.1;  } 50% { transform:translate(-50%,-50%) scale(1.7);  opacity:.2;  } }

.ch {
  position: absolute;
  top: 50%; left: 50%;
  border-radius: 50%;
  pointer-events: none;
}
.ch-1 { width: 210px; height: 210px; background: radial-gradient(circle, rgba(201,168,76,0.30) 0%, transparent 70%); animation: hpulse  3.2s ease-in-out infinite; }
