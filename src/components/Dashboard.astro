<!-- ════════════════════════════════════════════════════
     SCRIPT — Orbital animation + scaling
════════════════════════════════════════════════════ -->
<script>
  /* ── Theme toggle ── */
  const themeBtn = document.getElementById('theme-toggle');
  themeBtn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('gcb-theme', isDark ? 'dark' : 'light');
  });

  /* ── Orbit radii per screen size ── */
  function radii(w: number) {
    if (w >= 900) return { inner: 200, middle: 320, outer: 420 };
    if (w >= 680) return { inner: 158, middle: 252, outer: 330 };
    return               { inner: 125, middle: 200, outer: 265 };
  }

  /* ── Scale cosmos to available space ── */
  function scaleSystem() {
    const wrap   = document.getElementById('gcb-wrap');
    const cosmos = document.getElementById('gcb-cosmos');
    if (!wrap || !cosmos) return;
    const avW = wrap.clientWidth  - 20;
    const avH = wrap.clientHeight - 20;
    const s   = Math.min(avW / 920, avH / 920, 1);
    cosmos.style.transform = `scale(${s})`;
  }

  /* ── Planet state ── */
  interface PS { id: string; orbit: 'inner'|'middle'|'outer'; angle: number; speed: number; dir: number; lastTime: number|null; paused: boolean; }

  const raw: { id: string; orbit: string; phase: number; speed: number; dir: number }[] =
    JSON.parse((document.getElementById('gcb-data') as HTMLElement)?.dataset.v || '[]');

  const state: PS[] = raw.map(p => ({
    id: p.id,
    orbit: p.orbit as 'inner'|'middle'|'outer',
    angle: p.phase,
    speed: p.speed,
    dir:   p.dir,
    lastTime: null,
    paused: false,
  }));

  /* ── Animation loop ── */
  function animate(ts: number) {
    const r = radii(window.innerWidth);

    for (const s of state) {
      const el = document.getElementById(s.id);
      if (!el) continue;

      if (!s.paused) {
        if (s.lastTime !== null) {
          const dt = ts - s.lastTime;
          s.angle = (s.angle + dt * s.speed * s.dir * 0.06) % 360;
        }
        s.lastTime = ts;
      } else {
        s.lastTime = ts; // keep lastTime fresh for smooth resume
      }

      const rad = (s.angle * Math.PI) / 180;
      const x   = Math.cos(rad) * r[s.orbit];
      const y   = Math.sin(rad) * r[s.orbit];

      el.style.transform = `translate(${x}px, ${y}px)`;
      el.classList.toggle('tip-below', y < 0);
    }

    requestAnimationFrame(animate);
  }

  /* ── Hover / focus: pause planet ── */
  for (const s of state) {
    const el = document.getElementById(s.id);
    if (!el) continue;

    el.addEventListener('mouseenter', () => { s.paused = true;  });
    el.addEventListener('mouseleave', () => { s.paused = false; });
    el.addEventListener('focusin',    () => { s.paused = true;  });
    el.addEventListener('focusout',   () => { s.paused = false; });

    /* Click on bubble (not tooltip) → open link */
    el.addEventListener('click', (e: MouseEvent) => {
      if (!(e.target as HTMLElement).closest('.ptip')) {
        const href = el.dataset.href;
        if (href) window.open(href, '_blank', 'noopener,noreferrer');
      }
    });

    /* Keyboard: Enter opens link */
    el.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') {
        const href = el.dataset.href;
        if (href) window.open(href, '_blank', 'noopener,noreferrer');
      }
    });
  }

  /* ── Cosmos click sound (subtle: stop propagation loop) ── */
  scaleSystem();
  window.addEventListener('resize', scaleSystem);
  requestAnimationFrame(animate);
</script>
